# OS
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Claude Code (local settings, not for sharing)
.claude/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/

# Compiled C extensions (pointnet2, knn — must be built on each machine)
libs/pointnet2/build/
libs/knn/build/
libs/pointnet2/*.so
libs/knn/*.so
libs/MinkowskiEngine/build/
libs/MinkowskiEngine/dist/
libs/MinkowskiEngine/*.egg-info/

# External library (too large for git; install separately on server)
/libs/graspnetAPI

# Training outputs
/results/
/logs/
/checkpoints/
*.log

# Precomputed text features (regenerate on server with precompute_text_features.py)
text_features/

# Dataset (never commit the dataset itself)
/data/
/graspnet/
graspness/

# Jupyter
.ipynb_checkpoints/
*.ipynb
